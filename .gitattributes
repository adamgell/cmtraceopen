# Ensure PowerShell scripts always have CRLF line endings (required by Windows PowerShell 5.1)
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Real-world log fixtures are byte-sensitive (UTF-8 BOM + CRLF); never normalize them.
src-tauri/tests/fixtures/** -text

# Keep the security-backported crate byte-for-byte comparable with its
# published source; upstream rustdoc lines include intentional trailing spaces.
vendor/time-0.3.36/** -text whitespace=-blank-at-eol
